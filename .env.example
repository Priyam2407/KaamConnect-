# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/

# JWT Secret (change to a long random string in production)
JWT_SECRET=kaamconnect_super_secret_jwt_key_change_me

# Server port
PORT=5000

# Commission percentage (default 10%)
COMMISSION_PERCENT=10

# Razorpay keys (get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Optional: Anthropic API for AI chatbot
ANTHROPIC_API_KEY=your_anthropic_api_key_here
